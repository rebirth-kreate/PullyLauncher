<?xml version="1.0" encoding="utf-8"?>
<!--
    Auto Backup ルール（API 30 以下向け）。API 31 以降は data_extraction_rules.xml が優先。

    include のみ指定することで、列挙したファイルだけをバックアップ対象にする。
    pully_hidden_prefs（非表示アプリ一覧）や app_icons は指定外のため自動除外される。
-->
<full-backup-content>
    <include domain="sharedpref" path="ui_config.xml" />
    <include domain="sharedpref" path="pully_prefs.xml" />
</full-backup-content>
